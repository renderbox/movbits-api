[flake8]
max-line-length = 120
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    migrations,
    staticfiles,
    .eggs,
per-file-ignores =
    # Allow unused imports in __init__ files
    __init__.py: F401
    # Mock data files contain long URLs and description strings
    */mock_data.py: E501
