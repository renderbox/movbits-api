# Copy to .env and fill in values for local development.
# Never commit .env to version control.

# Django
DJANGO_SECRET_KEY=django-insecure-change-me
DEBUG=True
ENVIRONMENT=development

# Database — leave unset to use SQLite locally
# DATABASE_URL=postgresql://user:password@localhost:5432/movbits

# Redis
REDIS_URL=redis://localhost:6379

# GCP
GCP_PROJECT_ID=
EVENTS_BIGQUERY_DATASET=movbits_events_dev

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# AWS S3 (leave unset to skip S3 and use local media storage)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_MEDIA_BUCKET_NAME=

# Email
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Maintenance
MAINTENANCE_MODE=False

# SSO (comma-separated provider IDs: google, facebook, tiktok, instagram)
SSO_ENABLED_PROVIDERS=
